# ─── SERVER ───────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── JWT SECRET (generate with: openssl rand -base64 32) ──
JWT_SECRET=your-super-secret-jwt-key-change-this

# ─── SHOPIFY PRIVATE APP (for your own store) ─────────────
# Get from: Shopify Admin → Settings → Apps → Develop Apps
SHOPIFY_STORE_DOMAIN=ikaufen.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# ─── SHOPIFY OAUTH APP (for selling to other stores) ──────
# Get from: partners.shopify.com → Apps → Create App
SHOPIFY_API_KEY=your-shopify-app-api-key
SHOPIFY_API_SECRET=your-shopify-app-api-secret
SHOPIFY_APP_URL=https://your-app.railway.app

# ─── GROK AI (xAI) ────────────────────────────────────────
XAI_API_KEY=xai-xxxxxxxxxxxxx

# ─── DATABASE ─────────────────────────────────────────────
# SQLite (default, no setup needed)
DB_PATH=./data/grokify.db

# PostgreSQL (for production — uncomment when ready)
# DATABASE_URL=postgresql://user:password@host:5432/grokify
